/**
 * Wraps a test function with the appropriate Vitest 'it' or 'it.skip' based on policy.
 */
export function runEval(
  policy: EvalPolicy,
  name: string,
  fn: () => Promise<void>,
  timeout?: number,
) {
  if (policy === 'USUALLY_PASSES' && !process.env['RUN_EVALS']) {
    it.skip(name, fn);
  } else {
    it(name, fn, timeout);
  }
}


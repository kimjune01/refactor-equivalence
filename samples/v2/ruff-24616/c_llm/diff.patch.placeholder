-    fn same_code_multiline_suppressions_with_different_ranges_can_become_redundant() {
-        assert_snapshot!(
-            suppress_all_in(r#"
-                from typing import TypeAlias
-
-                JsonValue: TypeAlias = dict[str, "JsonValue"] | list["JsonValue"] | int
-

-                def get_data() -> dict[str, JsonValue]:
-                    return {"home_assistant": {"entities": [{"entity_id": "sensor.test"}]}}
-
-
-                def f() -> None:
-                    diag = get_data()
-                    diag["home_assistant"]["entities"] = sorted(
-                        diag["home_assistant"]["entities"], key=lambda ent: ent["entity_id"]
-                    )
-                "#

func (c *checker) lookupFieldType(exprID int64, structType, fieldName string, requireJSONName bool) (*types.Type, bool) {
	if _, found := c.env.provider.FindStructType(structType); !found {
		// This should not happen, anyway, report an error.
		c.errors.unexpectedFailedResolution(exprID, c.locationByID(exprID), structType)
		return nil, false
	}

	ft, found := c.env.provider.FindStructFieldType(structType, fieldName)
	if !found {
		c.errors.undefinedField(exprID, c.locationByID(exprID), fieldName)
		return nil, false
	}
	if requireJSONName && !ft.IsJSONField {
		c.errors.undefinedField(exprID, c.locationByID(exprID), fieldName)
		return nil, false
	}

	return ft.Type, true

+func logicalRequestKeyFromCallOptions(opts []gax.CallOption) string {
+	if len(opts) == 0 {
+		return ""
+	}
+
+	var settings gax.CallSettings
+	for _, opt := range opts {
+		if opt == nil {
+			continue
+		}

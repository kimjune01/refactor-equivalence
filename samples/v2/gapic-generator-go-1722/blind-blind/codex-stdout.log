@@ -531,2 +531,28 @@
 
+func (g *generator) emitResourceNameTelemetry(m *descriptorpb.MethodDescriptorProto, resTarget *heuristicTarget) {
+	g.printf("if gax.IsFeatureEnabled(\"TRACING\") || gax.IsFeatureEnabled(\"LOGGING\") {")
+
+	var getters []string
+	for _, f := range resTarget.FieldNames {
+		getters = append(getters, fmt.Sprintf("req%s", fieldGetter(f)))
+	}
+	gettersStr := strings.Join(getters, ", ")
+
+	serv := g.descInfo.ParentElement[m].(*descriptorpb.ServiceDescriptorProto)
+	host := ""
+	if proto.HasExtension(serv.Options, annotations.E_DefaultHost) {
+		host = proto.GetExtension(serv.Options, annotations.E_DefaultHost).(string)
+	}
+
+	escapedFormat := strings.ReplaceAll(resTarget.Format, "%", "%%")
+	if host != "" {
+		g.printf(`  ctx = callctx.WithTelemetryContext(ctx, "resource_name", fmt.Sprintf("//%s/`+escapedFormat+`", `+gettersStr+`))`, host)
+	} else {
+		g.printf(`  ctx = callctx.WithTelemetryContext(ctx, "resource_name", fmt.Sprintf("` + escapedFormat + `", ` + gettersStr + `))`)
+	}
+	g.printf("}")
+	g.imports[pbinfo.ImportSpec{Path: "github.com/googleapis/gax-go/v2/callctx"}] = true
+	g.imports[pbinfo.ImportSpec{Path: "fmt"}] = true
+}
+
 // insertAutoPopulatedFields generates the conditional initialization of any

+
+function contentPartsToText(parts: ContentPart[]): string {
+  return parts
+    .map((part) => {
+      if (part.type === 'text') {
+        return part.text;
+      }
+      if (part.type === 'reference') {
+        return part.text;
+      }
+      return '';

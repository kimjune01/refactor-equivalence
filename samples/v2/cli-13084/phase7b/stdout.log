+		case OrderByCreated:
+			orderField = githubv4.DiscussionOrderFieldCreatedAt
+		case OrderByUpdated:
+			orderField = githubv4.DiscussionOrderFieldUpdatedAt
+		default:
+			return nil, fmt.Errorf("unknown order-by field: %q", filters.OrderBy)
+		}
+	}
+	if filters.Direction != "" {

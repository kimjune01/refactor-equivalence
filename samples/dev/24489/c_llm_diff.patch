+ * exactly one property).
+ */
+function getSingleSchemaPropertyKey(schema: unknown): string | undefined {
+  if (!isRecord(schema)) {
+    return undefined;
+  }
+  const properties = schema['properties'];
+  if (!isRecord(properties)) {
+    return undefined;
+  }
+  const keys = Object.keys(properties);
+  if (keys.length !== 1) {
+    return undefined;
+  }
+  return keys[0];

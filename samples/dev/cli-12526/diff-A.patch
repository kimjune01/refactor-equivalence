+			editable.Metadata.AssignableActors = append(editable.Metadata.AssignableActors, a)
+		}
+		return prompter.MultiSelectSearchResult{
+			Keys:        logins,
+			Labels:      displayNames,
+			MoreResults: 0,
+			Err:         nil,
+		}
+	}
+}

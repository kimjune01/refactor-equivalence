+func (d *detector) ProjectFeatures() (ProjectFeatures, error) {
+	if !ghauth.IsEnterprise(d.host) {
+		return allProjectFeatures, nil
+	}
+
+	var featureDetection struct {
+		ProjectV2 struct {
+			Fields []struct {
+				Name string
+				Args []struct {
+					Name string
+				}
+			} `graphql:"fields(includeDeprecated: true)"`
+		} `graphql:"ProjectV2: __type(name: \"ProjectV2\")"`
+	}
+
+	gql := api.NewClientFromHTTP(d.httpClient)
+	if err := gql.Query(d.host, "ProjectV2_fields", &featureDetection, nil); err != nil {
+		return ProjectFeatures{}, err
+	}
+
+	for _, field := range featureDetection.ProjectV2.Fields {
+		if field.Name != "items" {
+			continue
+		}
+		for _, arg := range field.Args {
+			if arg.Name == "query" {
+				return ProjectFeatures{ProjectItemQuery: true}, nil
+			}
+		}
+	}
+
+	return ProjectFeatures{}, nil
 }
 

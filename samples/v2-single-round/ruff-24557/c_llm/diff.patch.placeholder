+    /// Information about the checkable code block(s) that compose this file.
+    code_blocks: Vec<CodeBlock<'a>>,
+}
+
+impl TestFile<'_> {
+    pub(crate) fn to_code_block_backtick_offsets(&self) -> Vec<BacktickOffsets> {
+        self.code_blocks
+            .iter()
+            .map(parser::CodeBlock::backtick_offsets)
+            .collect()

+        code: &'s str,
+        offsets: BacktickOffsets,
+    ) -> anyhow::Result<()> {
+        let Some(file) = self.files.last_mut() else {
+            bail!(
+                "Inline diagnostics block must follow a checkable Python file in the same section."

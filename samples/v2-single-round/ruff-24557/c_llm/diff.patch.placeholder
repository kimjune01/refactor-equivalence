+            "File `{}` has more than one inline diagnostics block.",
+            file.relative_path(),
+        );
+
+        code_block.inline_snapshot_block = Some(InlineSnapshotBlock {
+            expected: code,
+            range: offsets,
+        });
+
+        Ok(())
+    }

	t.Parallel()
	testdata := analysistest.TestData()
	plugin, _ := New(nil)
	analyzers, _ := plugin.BuildAnalyzers()
	analysistest.Run(t, testdata, analyzers[0], "has-warnings", "no-warnings")
}

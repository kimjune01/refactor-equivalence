+async function resolveInboxSkillSource(
+  config: Config,
+  dirName: string,
+): Promise<{ sourcePath: string } | { success: false; message: string }> {
+  if (!isValidInboxSkillDirName(dirName)) {
+    return { success: false, message: 'Invalid skill name.' };
+  }
+  const skillsDir = config.storage.getProjectSkillsMemoryDir();
+  const sourcePath = path.join(skillsDir, dirName);
+  try {
+    await fs.access(sourcePath);
+  } catch {
+    return { success: false, message: `Skill "${dirName}" not found in inbox.` };
+  }
+  return { sourcePath };
+}

-  if (eligible.length === 0) {
-    return { sessionIndex: '', newSessionIds: [] };
-  }
-
-  const lines: string[] = [];
-  const newSessionIds: string[] = [];
-
-  for (const { conversation, filePath } of eligible) {
-    const userMessageCount = conversation.messages.filter(
-      (m) => m.type === 'user',

-	file, err := f.filesystem.Open(skillFilePath)
-	if err != nil {
-		if errors.Is(err, fs.ErrNotExist) {
-			return nil, nil, nil, fmt.Errorf("%w: %q", ErrSkillNotFound, name)
-		}
-		return nil, nil, nil, fmt.Errorf("open %q: %w", skillFilePath, err)
-	}

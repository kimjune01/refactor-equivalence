-	if frontmatter.Name != name {
-		_ = file.Close()
-		return nil, nil, nil, fmt.Errorf("%w: name in SKILL.md (%q) does not match directory name (%q)", ErrInvalidSkillName, frontmatter.Name, name)
-	}
-	return frontmatter, reader, file, nil

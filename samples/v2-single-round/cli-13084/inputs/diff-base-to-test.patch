+	}
+
+	d.ReactionGroups = make([]ReactionGroup, len(n.ReactionGroups))
+	for i, rg := range n.ReactionGroups {
+		d.ReactionGroups[i] = ReactionGroup{Content: rg.Content, TotalCount: rg.Users.TotalCount}
+	}
+
